# Required — powers the AI agent, extraction, and medical review
GROQ_API_KEY=gsk_your_key_here

# Optional — additional keys for rate limit rotation (free tier: 100K tokens/day per key)
# GROQ_API_KEY_2=gsk_second_key
# GROQ_API_KEY_3=gsk_third_key

# Optional — model selection (default: meta-llama/llama-4-scout-17b-16e-instruct)
# Options: meta-llama/llama-4-scout-17b-16e-instruct (30K TPM, tool calling), openai/gpt-oss-20b (8K TPM)
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional — enables Gemini Vision fallback for handwritten/blurry document OCR
# GEMINI_API_KEY=your_gemini_key

# Database — use Turso cloud or local SQLite
TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=your_turso_token
